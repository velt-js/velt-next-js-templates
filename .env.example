# Velt Collaboration SDK
# Get your credentials from https://console.velt.dev
#
# 1. Sign up or log in at https://console.velt.dev
# 2. Create a new project (or use an existing one)
# 3. Copy your API Key and Auth Token from the project settings
#
# NEXT_PUBLIC_VELT_API_KEY is used client-side to initialize the Velt SDK
# VELT_AUTH_TOKEN is used server-side only to generate JWT tokens for users

NEXT_PUBLIC_VELT_API_KEY=
VELT_AUTH_TOKEN=
